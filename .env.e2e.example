# Credenciais para a suíte E2E (Playwright)
# Copie para .env.e2e e preencha. Nunca commite .env.e2e.

E2E_USER_EMAIL=
E2E_USER_PASSWORD=

# Opcional: para os specs do módulo /admin
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=

# Opcional: roda contra preview/staging em vez de localhost
# E2E_BASE_URL=https://meu-preview.lovable.app

# ---------------------------------------------------------------------------
# Testes de integração LIVE das Edge Functions (tests/edge-functions/live/)
# ---------------------------------------------------------------------------
# Sem estas vars, a suíte LIVE faz skip silencioso (CI verde).
# RECOMENDADO: aponte para STAGING/PREVIEW ao exercitar happy-paths.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Conta dev (role dev) para happy-paths de funções dev-only. Opcional.
E2E_DEV_EMAIL=
E2E_DEV_PASSWORD=

# Opcional: habilita happy-paths CAROS (geração de imagem/IA) — default desligado.
# EDGE_LIVE_COSTLY=1
# Opcional: timeout por request live (ms). Default 15000.
# EDGE_LIVE_TIMEOUT_MS=15000
